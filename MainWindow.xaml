<Window x:Class="RdpManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="RDP Manager"
        Width="1400"
        Height="880"
        MinWidth="1180"
        MinHeight="760"
        Background="#EAF0F7"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        ResizeMode="CanResize"
        WindowStyle="None"
        StateChanged="MainWindow_OnStateChanged"
        WindowStartupLocation="CenterScreen">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="7"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#EAF0F7" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#FBFBFD" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#D9E1EC" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#F5F7FB" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#202733" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#69788E" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#8895A8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#1F7BFF" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#E8F1FF" />
        <SolidColorBrush x:Key="AccentSoftBorderBrush" Color="#BFD6FF" />
        <SolidColorBrush x:Key="DangerSoftBrush" Color="#FFF1F1" />
        <SolidColorBrush x:Key="DangerSoftBorderBrush" Color="#F5C7C7" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="NavItemStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ButtonBaseStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}">
            <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerSoftBorderBrush}" />
            <Setter Property="Foreground" Value="#B33838" />
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TitleBarButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TitleBarButtonBorder" Property="Background" Value="#EDF2FA" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TitleBarButtonBorder" Property="Background" Value="#E3EAF5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TitleBarCloseButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TitleBarCloseButtonBorder" Property="Background" Value="#D13438" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TitleBarCloseButtonBorder" Property="Background" Value="#B91C1C" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="58" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentSoftBorderBrush}" />
        </Style>

        <Style x:Key="GridDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource GridActionButtonStyle}">
            <Setter Property="Foreground" Value="#B33838" />
            <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DangerSoftBorderBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="12,0,12,0"
                                          VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MultilineTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Height" Value="104" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="12"
                                          VerticalAlignment="Stretch" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="12,0,12,0"
                                          VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterChipButtonStyle" TargetType="Button" BasedOn="{StaticResource ButtonBaseStyle}">
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="50" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="FilterGroupLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,7,10,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="FilterFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SidebarSectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="FilterComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Margin="4,2"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F1F6FF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#E8F1FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="168" />
            <Setter Property="Padding" Value="12,0,36,0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource FilterComboBoxItemStyle}" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="MaxDropDownHeight" Value="320" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Background="Transparent"
                                          BorderBrush="{x:Null}"
                                          BorderThickness="0"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    IsHitTestVisible="False" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              IsHitTestVisible="False" />
                            <TextBlock Margin="0,0,12,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="&#xE70D;"
                                       IsHitTestVisible="False" />
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border Margin="0,6,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="White"
                                        BorderBrush="{StaticResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer Margin="4"
                                                  CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource AccentSoftBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource AccentSoftBorderBrush}" />
                                <Setter TargetName="ComboBorder" Property="Background" Value="#FBFDFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                <Setter TargetName="ComboBorder" Property="Background" Value="#F3F4F7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridProxyComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource FilterComboBoxStyle}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="136" />
            <Setter Property="Padding" Value="10,0,30,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="HorizontalGridLinesBrush" Value="Transparent" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F7F9FC" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="BorderBrush" Value="#E2E8F1" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                    <Setter Property="Background" Value="Transparent" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Height" Value="52" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F4F8FF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DCEAFE" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource WindowBrush}"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1">
        <Grid Background="{StaticResource WindowBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="{StaticResource WindowBrush}"
                  MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <DockPanel Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           LastChildFill="True">
                    <Border Width="28"
                            Height="28"
                            Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="{StaticResource AccentSoftBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Text="&#xE72B;" />
                    </Border>
                    <TextBlock x:Name="WindowTitleTextBlock"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"
                               Text="RDP Manager" />
                </DockPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="0,6,6,6"
                            HorizontalAlignment="Right">
                    <Button x:Name="MinimizeWindowButton"
                            Click="MinimizeWindowButton_OnClick"
                            Content="&#xE921;"
                            Style="{StaticResource TitleBarButtonStyle}" />
                    <Button x:Name="MaximizeRestoreWindowButton"
                            Click="MaximizeRestoreWindowButton_OnClick"
                            Style="{StaticResource TitleBarButtonStyle}">
                        <TextBlock x:Name="MaximizeRestoreIconTextBlock"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Text="&#xE922;" />
                    </Button>
                    <Button x:Name="CloseWindowButton"
                            Click="CloseWindowButton_OnClick"
                            Content="&#xE8BB;"
                            Style="{StaticResource TitleBarCloseButtonStyle}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="292" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="14,0,0,14"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
                <Grid Margin="20,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <DockPanel LastChildFill="False">
                        <Border Width="34"
                                Height="34"
                                Background="{StaticResource AccentSoftBrush}"
                                BorderBrush="{StaticResource AccentSoftBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="15"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="&#xE72B;" />
                        </Border>
                        <StackPanel Margin="12,0,0,0">
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Text="RDP Manager" />
                            <TextBlock FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="Local-first workspace" />
                        </StackPanel>
                    </DockPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,20,0,0">
                    <TextBlock Style="{StaticResource SidebarSectionLabelStyle}"
                               Text="SEARCH" />
                    <TextBox x:Name="SearchTextBox"
                             ToolTip="Search HostName, Host, User, Group, Tags, and Notes"
                             TextChanged="SearchTextBox_OnTextChanged" />
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,22,0,0">
                    <TextBlock Style="{StaticResource SidebarSectionLabelStyle}"
                               Text="BROWSE" />
                    <Button x:Name="AllConnectionsNavButton"
                            Style="{StaticResource NavButtonStyle}"
                            Background="#F1F6FF"
                            Click="AllConnectionsNavButton_OnClick">
                        <DockPanel>
                            <TextBlock x:Name="AllConnectionsNavIcon" FontFamily="Segoe MDL2 Assets" Text="&#xE80F;" />
                            <TextBlock x:Name="AllConnectionsNavText" Margin="12,0,0,0" VerticalAlignment="Center" Text="All connections" />
                        </DockPanel>
                    </Button>
                    <Button x:Name="FavoritesNavButton"
                            Style="{StaticResource NavButtonStyle}"
                            Click="FavoritesNavButton_OnClick">
                        <DockPanel>
                            <TextBlock x:Name="FavoritesNavIcon" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextSecondaryBrush}" Text="&#xE734;" />
                            <TextBlock x:Name="FavoritesNavText" Margin="12,0,0,0" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Text="Favorites" />
                        </DockPanel>
                    </Button>
                    <Button x:Name="RecentNavButton"
                            Style="{StaticResource NavButtonStyle}"
                            Click="RecentNavButton_OnClick">
                        <DockPanel>
                            <TextBlock x:Name="RecentNavIcon" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextSecondaryBrush}" Text="&#xE823;" />
                            <TextBlock x:Name="RecentNavText" Margin="12,0,0,0" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Text="Recent" />
                        </DockPanel>
                    </Button>
                    <Button x:Name="CloudminiSyncNavButton"
                            Style="{StaticResource NavButtonStyle}"
                            Click="CloudminiSyncNavButton_OnClick">
                        <DockPanel>
                            <TextBlock x:Name="CloudminiSyncNavIcon" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextSecondaryBrush}" Text="&#xE753;" />
                            <TextBlock x:Name="CloudminiSyncNavText" Margin="12,0,0,0" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Text="Cloudmini Sync" />
                        </DockPanel>
                    </Button>
                </StackPanel>

                <StackPanel x:Name="ConnectionsActionsPanel" Grid.Row="3" Margin="0,24,0,0">
                    <TextBlock Style="{StaticResource SidebarSectionLabelStyle}"
                               Text="ACTIONS" />
                    <Button x:Name="ConnectButton"
                            Margin="0,0,0,10"
                            Click="ConnectButton_OnClick"
                            Content="Connect selected"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    <Button x:Name="CheckSelectedButton"
                            Margin="0,0,0,10"
                            Click="CheckSelectedButton_OnClick"
                            Content="Check selected"
                            Style="{StaticResource ButtonBaseStyle}" />
                    <Button x:Name="AddButton"
                            Margin="0,0,0,10"
                            Click="AddButton_OnClick"
                            Content="Add new entry"
                            Style="{StaticResource ButtonBaseStyle}" />
                    <Button x:Name="OpenCsvButton"
                            Margin="0,0,0,10"
                            Click="OpenCsvButton_OnClick"
                            Content="Import CSV"
                            Style="{StaticResource ButtonBaseStyle}" />
                    <Button x:Name="SaveButton"
                            Margin="0,0,0,10"
                            Click="SaveButton_OnClick"
                            Content="Save database"
                            Style="{StaticResource ButtonBaseStyle}" />
                    <Button x:Name="SaveAsButton"
                            Margin="0,0,0,10"
                            Click="SaveAsButton_OnClick"
                            Content="Export CSV"
                            Style="{StaticResource ButtonBaseStyle}" />
                    <Button x:Name="DeleteButton"
                            Click="DeleteButton_OnClick"
                            Content="Delete selected"
                            Style="{StaticResource DangerButtonStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="4"
                            VerticalAlignment="Bottom">
                    <Border Margin="0,0,0,14"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="0,1,0,0" />
                    <Button x:Name="SettingsNavButton"
                            Style="{StaticResource NavButtonStyle}"
                            Click="SettingsNavButton_OnClick">
                        <DockPanel>
                            <TextBlock x:Name="SettingsNavIcon" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource TextSecondaryBrush}" Text="&#xE713;" />
                            <TextBlock x:Name="SettingsNavText" Margin="12,0,0,0" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Text="Settings" />
                        </DockPanel>
                    </Button>
                    <TextBlock x:Name="VersionTagTextBlock"
                               Margin="12,10,0,0"
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="v1.2.0-phase2-local-ops" />
                </StackPanel>

            </Grid>
        </Border>

        <Grid Grid.Column="1"
              Margin="14,0,14,14">
            <Grid>
                <Grid x:Name="ConnectionsView" MinHeight="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="264" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Margin="0,0,16,0" MinHeight="0" Style="{StaticResource CardStyle}">
                        <Grid MinHeight="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock FontSize="24" FontWeight="Bold" Text="Saved connections" />
                                <TextBlock x:Name="ConnectionsSubtitleTextBlock"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="Click Host, User, or Password to copy. Search also matches group, tags, and notes. Use Connect to launch RDP." />
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Style="{StaticResource FilterFieldLabelStyle}"
                                                   Text="Platform" />
                                        <ComboBox x:Name="ConnectionsPlatformFilterComboBox"
                                                  SelectionChanged="ConnectionsPlatformFilterComboBox_OnSelectionChanged"
                                                  Style="{StaticResource FilterComboBoxStyle}">
                                            <ComboBoxItem Content="All platforms" Tag="All" Style="{StaticResource FilterComboBoxItemStyle}" />
                                            <ComboBoxItem Content="Windows only" Tag="Windows" Style="{StaticResource FilterComboBoxItemStyle}" />
                                            <ComboBoxItem Content="Linux only" Tag="Linux" Style="{StaticResource FilterComboBoxItemStyle}" />
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                        <TextBlock Style="{StaticResource FilterFieldLabelStyle}"
                                                   Text="Status" />
                                        <ComboBox x:Name="ConnectionsStatusFilterComboBox"
                                                  SelectionChanged="ConnectionsStatusFilterComboBox_OnSelectionChanged"
                                                  Style="{StaticResource FilterComboBoxStyle}">
                                            <ComboBoxItem Content="All statuses" Tag="All" Style="{StaticResource FilterComboBoxItemStyle}" />
                                            <ComboBoxItem Content="Online" Tag="Online" Style="{StaticResource FilterComboBoxItemStyle}" />
                                            <ComboBoxItem Content="Offline" Tag="Offline" Style="{StaticResource FilterComboBoxItemStyle}" />
                                            <ComboBoxItem Content="Other" Tag="Other" Style="{StaticResource FilterComboBoxItemStyle}" />
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource FilterFieldLabelStyle}"
                                                   Text="Group" />
                                        <ComboBox x:Name="ConnectionsGroupFilterComboBox"
                                                  SelectionChanged="ConnectionsGroupFilterComboBox_OnSelectionChanged"
                                                  Style="{StaticResource FilterComboBoxStyle}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                            <Grid Grid.Row="1" MinHeight="0">
                                <DataGrid x:Name="EntriesGrid"
                                           AutoGenerateColumns="False"
                                           CanUserAddRows="False"
                                           IsReadOnly="True"
                                           MinHeight="0"
                                           SelectionMode="Single"
                                           SelectionUnit="FullRow"
                                           SelectionChanged="EntriesGrid_OnSelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Width="1.15*" Header="Host">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Host}"
                                                               Cursor="Hand"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="Click to copy host"
                                                               Tag="{Binding Host}"
                                                               MouseLeftButtonUp="CopyValueTextBlock_OnMouseLeftButtonUp" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Width="0.6*" Binding="{Binding Port}" Header="Port" />
                                        <DataGridTemplateColumn Width="0.85*" Header="User">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding User}"
                                                               Cursor="Hand"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="Click to copy user"
                                                               Tag="{Binding User}"
                                                               MouseLeftButtonUp="CopyValueTextBlock_OnMouseLeftButtonUp" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Width="0.75*" Header="Password">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding MaskedPassword}"
                                                               Cursor="Hand"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="Click to copy password"
                                                               Tag="{Binding Password}"
                                                               MouseLeftButtonUp="CopyValueTextBlock_OnMouseLeftButtonUp" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Width="1.0*" Header="Proxy">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox Margin="0"
                                                              DisplayMemberPath="DisplayName"
                                                              SelectedValuePath="SelectionKey"
                                                              SelectedValue="{Binding ProxySelectionKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              TextSearch.TextPath="DisplayName"
                                                              ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=EntryProxyOptions}"
                                                              SelectionChanged="EntryGridProxyComboBox_OnSelectionChanged"
                                                              Style="{StaticResource GridProxyComboBoxStyle}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Width="0.8*" Binding="{Binding StatusLabel}" Header="Status" />
                                        <DataGridTemplateColumn Width="0.8*" Header="Health">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding HealthLabel}"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding HealthDetails}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Width="236" Header="Action">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid VerticalAlignment="Center" HorizontalAlignment="Left">
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                            <Button Content="Connect"
                                                                    Style="{StaticResource GridActionButtonStyle}"
                                                                    Tag="{Binding}"
                                                                    Click="RowConnectButton_OnClick" />
                                                            <Button Content="Edit"
                                                                    Style="{StaticResource GridActionButtonStyle}"
                                                                    Tag="{Binding}"
                                                                    Click="RowEditButton_OnClick" />
                                                            <Button Content="Delete"
                                                                    Margin="0"
                                                                    Style="{StaticResource GridDangerButtonStyle}"
                                                                    Tag="{Binding}"
                                                                    Click="RowDeleteButton_OnClick" />
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBlock x:Name="EmptyStateTextBlock"
                                           Margin="0,72,0,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="14"
                                           Text="No connections to show."
                                           Visibility="Collapsed" />
                            </Grid>
                            <Grid Grid.Row="2" Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="PageInfoTextBlock"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="Page 1 / 1" />
                                <TextBlock x:Name="PageCountSummaryTextBlock"
                                           Grid.Column="1"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="0 items" />
                                <Button x:Name="CheckPageButton"
                                        Grid.Column="2"
                                        Margin="0,0,8,0"
                                        Click="CheckPageButton_OnClick"
                                        Content="Check page"
                                        Style="{StaticResource ButtonBaseStyle}" />
                                <Button x:Name="PreviousPageButton"
                                        Grid.Column="3"
                                        Margin="0,0,8,0"
                                        Click="PreviousPageButton_OnClick"
                                        Content="Previous"
                                        Style="{StaticResource ButtonBaseStyle}" />
                                <Button x:Name="NextPageButton"
                                        Grid.Column="4"
                                        Click="NextPageButton_OnClick"
                                        Content="Next"
                                        Style="{StaticResource ButtonBaseStyle}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" MinHeight="0" Style="{StaticResource CardStyle}">
                        <Grid MinHeight="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="24" FontWeight="Bold" Text="Entry editor" />
                                <Button x:Name="FavoriteButton"
                                        Grid.Column="1"
                                        Width="40"
                                        Height="40"
                                        Margin="12,0,0,0"
                                        Click="FavoriteButton_OnClick"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="16"
                                        Padding="0"
                                        HorizontalContentAlignment="Center"
                                        Content="&#xE734;"
                                        Style="{StaticResource ButtonBaseStyle}" />
                            </Grid>
                            <TextBlock Grid.Row="1"
                                       Margin="0,6,0,18"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="HostName is your display label. Host should be the real IP or DNS target." 
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="HOSTNAME" />
                            <TextBox x:Name="HostNameTextBox"
                                     Grid.Row="3"
                                     Margin="0,8,0,14"
                                     TextChanged="Editor_OnTextChanged" />

                            <Grid Grid.Row="4" Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="HOST" />
                                    <TextBox x:Name="HostTextBox"
                                             Margin="0,8,0,0"
                                             TextChanged="Editor_OnTextChanged" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="PORT" />
                                    <TextBox x:Name="PortTextBox"
                                             Margin="0,8,0,0"
                                             Text="3389"
                                             TextChanged="Editor_OnTextChanged" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Grid.Row="5" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="USER" />
                            <TextBox x:Name="UserTextBox"
                                     Grid.Row="6"
                                     Margin="0,8,0,14"
                                     TextChanged="Editor_OnTextChanged" />

                            <TextBlock Grid.Row="7" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="PASSWORD" />
                            <PasswordBox x:Name="PasswordBox"
                                         Grid.Row="8"
                                         Margin="0,8,0,14"
                                         PasswordChanged="PasswordBox_OnPasswordChanged" />

                            <StackPanel Grid.Row="9" Margin="0,0,0,14">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="PROXY" />
                                <ComboBox x:Name="EntryProxyComboBox"
                                          Margin="0,8,0,0"
                                          DisplayMemberPath="DisplayName"
                                          TextSearch.TextPath="DisplayName"
                                          SelectionChanged="EntryProxyComboBox_OnSelectionChanged"
                                          Style="{StaticResource FilterComboBoxStyle}" />
                            </StackPanel>

                            <Grid Grid.Row="10" Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="GROUP" />
                                    <TextBox x:Name="GroupTextBox"
                                             Margin="0,8,0,0"
                                             TextChanged="Editor_OnTextChanged" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="TAGS" />
                                    <TextBox x:Name="TagsTextBox"
                                            Margin="0,8,0,0"
                                             TextChanged="Editor_OnTextChanged" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="11">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="NOTES" />
                                <TextBox x:Name="NotesTextBox"
                                         Margin="0,8,0,0"
                                         MaxHeight="96"
                                         TextChanged="Editor_OnTextChanged"
                                         Style="{StaticResource MultilineTextBoxStyle}" />
                            </StackPanel>

                            <Grid Grid.Row="12" Margin="0,22,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="ApplyButton"
                                        Grid.Column="0"
                                        Margin="0,0,8,0"
                                        Click="ApplyButton_OnClick"
                                        Content="Apply entry"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                                <Button x:Name="ClearButton"
                                        Grid.Column="1"
                                        Margin="8,0,0,0"
                                        Click="ClearButton_OnClick"
                                        Content="Clear form"
                                        Style="{StaticResource ButtonBaseStyle}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Border x:Name="CloudminiView"
                        Visibility="Collapsed"
                        Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="24" FontWeight="Bold" Text="Cloudmini Sync" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Test token, fetch VPS from Cloudmini, preview changes, and sync them into your local RDP list."
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,20,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="CLOUDMINI TOKEN" />
                                <PasswordBox x:Name="CloudminiTokenPasswordBox"
                                             Margin="0,8,0,0" />
                                <CheckBox x:Name="RememberCloudminiTokenCheckBox"
                                          Margin="0,10,0,0"
                                          Content="Remember token on this machine" />
                            </StackPanel>
                            <Button x:Name="TestCloudminiButton"
                                    Grid.Column="1"
                                    Margin="0,20,12,0"
                                    VerticalAlignment="Top"
                                    Click="TestCloudminiButton_OnClick"
                                    Content="Test connection"
                                    Style="{StaticResource ButtonBaseStyle}" />
                            <Button x:Name="FetchCloudminiButton"
                                    Grid.Column="2"
                                    Margin="0,20,0,0"
                                    VerticalAlignment="Top"
                                    Click="FetchCloudminiButton_OnClick"
                                    Content="Fetch VPS"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Margin="0,0,8,0"
                                    Padding="16"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="ACCOUNT" />
                                    <TextBlock x:Name="CloudminiAccountSummaryTextBlock"
                                               Margin="0,8,0,0"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Not connected" />
                                    <TextBlock x:Name="CloudminiStatusTextBlock"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="Enter a token and test the connection." 
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Padding="16"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <StackPanel>
                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="SYNC OPTIONS" />
                                    <CheckBox x:Name="KeepLocalHostNameCheckBox"
                                              Margin="0,10,0,0"
                                              Checked="CloudminiOptionCheckBox_OnChanged"
                                              Unchecked="CloudminiOptionCheckBox_OnChanged"
                                              Content="Keep local HostName" />
                                    <CheckBox x:Name="OverwritePasswordCheckBox"
                                              Margin="0,8,0,0"
                                              Checked="CloudminiOptionCheckBox_OnChanged"
                                              Unchecked="CloudminiOptionCheckBox_OnChanged"
                                              Content="Overwrite password from provider" />
                                    <CheckBox x:Name="ImportOnlyOnlineCheckBox"
                                              Margin="0,8,0,0"
                                              Checked="CloudminiOptionCheckBox_OnChanged"
                                              Unchecked="CloudminiOptionCheckBox_OnChanged"
                                              Content="Import only online VPS" />
                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Style="{StaticResource FilterFieldLabelStyle}"
                                                       Text="Platform" />
                                            <ComboBox x:Name="CloudminiPlatformFilterComboBox"
                                                      SelectionChanged="CloudminiPlatformFilterComboBox_OnSelectionChanged"
                                                      Style="{StaticResource FilterComboBoxStyle}">
                                                <ComboBoxItem Content="All platforms" Tag="All" Style="{StaticResource FilterComboBoxItemStyle}" />
                                                <ComboBoxItem Content="Windows only" Tag="Windows" Style="{StaticResource FilterComboBoxItemStyle}" />
                                                <ComboBoxItem Content="Linux only" Tag="Linux" Style="{StaticResource FilterComboBoxItemStyle}" />
                                            </ComboBox>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Style="{StaticResource FilterFieldLabelStyle}"
                                                       Text="Status" />
                                            <ComboBox x:Name="CloudminiStatusFilterComboBox"
                                                      SelectionChanged="CloudminiStatusFilterComboBox_OnSelectionChanged"
                                                      Style="{StaticResource FilterComboBoxStyle}">
                                                <ComboBoxItem Content="All statuses" Tag="All" Style="{StaticResource FilterComboBoxItemStyle}" />
                                                <ComboBoxItem Content="Online" Tag="Online" Style="{StaticResource FilterComboBoxItemStyle}" />
                                                <ComboBoxItem Content="Offline" Tag="Offline" Style="{StaticResource FilterComboBoxItemStyle}" />
                                                <ComboBoxItem Content="Other" Tag="Other" Style="{StaticResource FilterComboBoxItemStyle}" />
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="3">
                            <DataGrid x:Name="CloudminiPreviewGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="False"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Width="70"
                                                            Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Header="Sync" />
                                    <DataGridTextColumn Width="90"
                                                        Binding="{Binding SourceId}"
                                                        IsReadOnly="True"
                                                        Header="VPS ID" />
                                    <DataGridTextColumn Width="1.2*"
                                                        Binding="{Binding Ip}"
                                                        IsReadOnly="True"
                                                        Header="IP" />
                                    <DataGridTextColumn Width="0.7*"
                                                        Binding="{Binding Port}"
                                                        IsReadOnly="True"
                                                        Header="Port" />
                                    <DataGridTextColumn Width="0.9*"
                                                        Binding="{Binding User}"
                                                        IsReadOnly="True"
                                                        Header="User" />
                                    <DataGridTextColumn Width="0.9*"
                                                        Binding="{Binding StatusDisplay}"
                                                        IsReadOnly="True"
                                                        Header="Status" />
                                    <DataGridTextColumn Width="0.9*"
                                                        Binding="{Binding Platform}"
                                                        IsReadOnly="True"
                                                        Header="Platform" />
                                    <DataGridTextColumn Width="1.1*"
                                                        Binding="{Binding Location}"
                                                        IsReadOnly="True"
                                                        Header="Location" />
                                    <DataGridTextColumn Width="1.0*"
                                                        Binding="{Binding ExpiredAtDisplay}"
                                                        IsReadOnly="True"
                                                        Header="Expires" />
                                    <DataGridTextColumn Width="0.9*"
                                                        Binding="{Binding SyncAction}"
                                                        IsReadOnly="True"
                                                        Header="Action" />
                                    <DataGridTextColumn Width="1.3*"
                                                        Binding="{Binding Note}"
                                                        IsReadOnly="True"
                                                        Header="Note" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock x:Name="CloudminiEmptyStateTextBlock"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="14"
                                       Text="No Cloudmini VPS loaded yet."
                                       Visibility="Visible" />
                        </Grid>

                        <Grid Grid.Row="4" Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CloudminiLastSyncTextBlock"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Last sync: never" />
                            <Button x:Name="SyncSelectedCloudminiButton"
                                    Grid.Column="1"
                                    Margin="12,0,8,0"
                                    Click="SyncSelectedCloudminiButton_OnClick"
                                    Content="Sync selected"
                                    Style="{StaticResource ButtonBaseStyle}" />
                            <Button x:Name="SyncAllCloudminiButton"
                                    Grid.Column="2"
                                    Click="SyncAllCloudminiButton_OnClick"
                                    Content="Sync all"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border x:Name="SettingsView"
                        Visibility="Collapsed"
                        Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="24" FontWeight="Bold" Text="Settings" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                          Text="Manage Cloudmini token storage, local diagnostics, and shared SSH proxy server profiles."
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Button x:Name="BackToConnectionsButton"
                                    Grid.Column="1"
                                    Click="BackToConnectionsButton_OnClick"
                                    Content="Back to connections"
                                    Style="{StaticResource ButtonBaseStyle}" />
                        </Grid>

                        <ScrollViewer Grid.Row="1"
                                      Margin="0,20,0,0"
                                      VerticalScrollBarVisibility="Auto">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.92*" />
                                    <ColumnDefinition Width="1.38*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Margin="0,0,16,0">
                                    <Border Padding="16"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="DEFAULT SYNC SETTINGS" />
                                            <CheckBox x:Name="SettingsKeepLocalHostNameCheckBox"
                                                      Margin="0,10,0,0"
                                                      Content="Keep local HostName by default" />
                                            <CheckBox x:Name="SettingsOverwritePasswordCheckBox"
                                                      Margin="0,8,0,0"
                                                      Content="Overwrite password from provider by default" />
                                            <CheckBox x:Name="SettingsImportOnlyOnlineCheckBox"
                                                      Margin="0,8,0,0"
                                                      Content="Import only online VPS by default" />
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,16,0,0"
                                            Padding="16"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="DIAGNOSTICS" />
                                            <TextBlock x:Name="CurrentCsvPathTextBlock"
                                                       Margin="0,10,0,0"
                                                       TextWrapping="Wrap"
                                                       Text="Database: -" />
                                            <TextBlock x:Name="SettingsPathTextBlock"
                                                       Margin="0,8,0,0"
                                                       TextWrapping="Wrap"
                                                       Text="Settings: -" />
                                            <TextBlock x:Name="JumpHostsPathTextBlock"
                                                       Margin="0,8,0,0"
                                                       TextWrapping="Wrap"
                                                      Text="Proxy servers: -" />
                                            <TextBlock x:Name="SecretVaultPathTextBlock"
                                                       Margin="0,8,0,0"
                                                       TextWrapping="Wrap"
                                                       Text="Secrets: -" />
                                            <TextBlock x:Name="SavedTokenStatusTextBlock"
                                                       Margin="0,8,0,0"
                                                       TextWrapping="Wrap"
                                                       Text="Saved token: not stored" />
                                            <TextBlock x:Name="JumpHostCountTextBlock"
                                                       Margin="0,8,0,0"
                                                       TextWrapping="Wrap"
                                                       Text="Proxy server profiles: 0" />
                                            <TextBlock x:Name="AppVersionTextBlock"
                                                       Margin="0,8,0,0"
                                                       TextWrapping="Wrap"
                                                       Text="Version: -" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Padding="16"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="PROXY SERVERS" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="Shared proxy server profiles for SSH tunnel connections."
                                                       TextWrapping="Wrap" />
                                            <Border Margin="0,12,0,0"
                                                    Padding="8"
                                                    Background="White"
                                                    BorderBrush="{StaticResource CardBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <ListBox x:Name="JumpHostProfilesListBox"
                                                         MinHeight="300"
                                                         BorderThickness="0"
                                                         SelectionChanged="JumpHostProfilesListBox_OnSelectionChanged">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Margin="2">
                                                                <TextBlock FontWeight="SemiBold"
                                                                           Text="{Binding DisplayName}" />
                                                                <TextBlock FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           Text="{Binding Host}" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Border>
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="AddJumpHostProfileButton"
                                                        Margin="0,0,8,0"
                                                        Click="AddJumpHostProfileButton_OnClick"
                                                        Content="Add proxy"
                                                        Style="{StaticResource ButtonBaseStyle}" />
                                                <Button x:Name="DeleteJumpHostProfileButton"
                                                        Grid.Column="1"
                                                        Margin="8,0,0,0"
                                                        Click="DeleteJumpHostProfileButton_OnClick"
                                                        Content="Delete proxy"
                                                        Style="{StaticResource DangerButtonStyle}" />
                                            </Grid>
                                        </StackPanel>

                                        <Grid Grid.Column="2">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Proxy server editor" />
                                                    <TextBlock Margin="0,6,0,0"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               Text="Shared password-based proxy settings for SSH tunnels."
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        VerticalAlignment="Top"
                                                        Padding="10,6"
                                                        Background="#F5F8FD"
                                                        BorderBrush="{StaticResource CardBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="10">
                                                    <TextBlock FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               Text="SSH PASSWORD" />
                                                </Border>
                                                <ComboBox x:Name="JumpHostAuthModeComboBox"
                                                          Width="1"
                                                          Height="1"
                                                          HorizontalAlignment="Right"
                                                          VerticalAlignment="Top"
                                                          Opacity="0"
                                                          IsHitTestVisible="False"
                                                          SelectionChanged="JumpHostAuthModeComboBox_OnSelectionChanged"
                                                          Style="{StaticResource FilterComboBoxStyle}">
                                                    <ComboBoxItem Content="Password" Tag="Password" Style="{StaticResource FilterComboBoxItemStyle}" />
                                                </ComboBox>
                                            </Grid>

                                            <Grid Grid.Row="1" Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="96" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Margin="0,0,12,0">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="PROFILE NAME" />
                                                    <TextBox x:Name="JumpHostProfileNameTextBox"
                                                             Margin="0,6,0,0" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="HOST" />
                                                    <TextBox x:Name="JumpHostHostTextBox"
                                                             Margin="0,6,0,0" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="PORT" />
                                                    <TextBox x:Name="JumpHostPortTextBox"
                                                             Margin="0,6,0,0"
                                                             Text="22" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid Grid.Row="2" Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Margin="0,0,12,0">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="USER" />
                                                    <TextBox x:Name="JumpHostUserTextBox"
                                                             Margin="0,6,0,0" />
                                                </StackPanel>
                                                <StackPanel x:Name="JumpHostPasswordPanel"
                                                            Grid.Column="1"
                                                            Visibility="Collapsed">
                                                    <TextBlock FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               Text="PASSWORD" />
                                                    <PasswordBox x:Name="JumpHostPasswordBox"
                                                                 Margin="0,6,0,0" />
                                                    <TextBlock x:Name="JumpHostPasswordHintTextBlock"
                                                               Margin="0,6,0,0"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               Text="Leave blank to keep the stored password for this profile."
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid Grid.Row="3" Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="96" />
                                                    <ColumnDefinition Width="96" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Margin="0,0,12,0">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="HOST KEY FINGERPRINT" />
                                                    <TextBox x:Name="JumpHostHostKeyFingerprintTextBox"
                                                             Margin="0,6,0,0" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="TIMEOUT" />
                                                    <TextBox x:Name="JumpHostConnectTimeoutTextBox"
                                                             Margin="0,6,0,0"
                                                             Text="10" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="KEEPALIVE" />
                                                    <TextBox x:Name="JumpHostKeepAliveTextBox"
                                                             Margin="0,6,0,0"
                                                             Text="30" />
                                                </StackPanel>
                                            </Grid>

                                            <Border Grid.Row="4"
                                                    Margin="0,12,0,0"
                                                    Padding="14"
                                                    Background="White"
                                                    BorderBrush="{StaticResource CardBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Margin="0,0,18,0" VerticalAlignment="Center">
                                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Text="PASSWORD STATUS" />
                                                        <TextBlock x:Name="JumpHostKeyStatusTextBlock"
                                                                   Margin="0,6,0,0"
                                                                   TextWrapping="Wrap"
                                                                   Text="No SSH secret stored for this profile." />
                                                        <TextBlock x:Name="JumpHostTestStatusTextBlock"
                                                                   Margin="0,4,0,0"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap"
                                                                   Text="SSH test not run yet." />
                                                    </StackPanel>
                                                    <Button x:Name="ImportJumpHostKeyButton"
                                                            Grid.Column="1"
                                                            Width="0"
                                                            Height="0"
                                                            Margin="0"
                                                            Visibility="Collapsed"
                                                            Click="ImportJumpHostKeyButton_OnClick"
                                                            Content="Import key"
                                                            Style="{StaticResource ButtonBaseStyle}" />
                                                    <Button x:Name="ClearJumpHostKeyButton"
                                                            Grid.Column="2"
                                                            Margin="0,0,10,0"
                                                            VerticalAlignment="Center"
                                                            Click="ClearJumpHostKeyButton_OnClick"
                                                            Content="Clear password"
                                                            Style="{StaticResource ButtonBaseStyle}" />
                                                    <Button x:Name="TestJumpHostProfileButton"
                                                            Grid.Column="3"
                                                            Margin="0,0,10,0"
                                                            VerticalAlignment="Center"
                                                            Click="TestJumpHostProfileButton_OnClick"
                                                            Content="Test SSH"
                                                            Style="{StaticResource ButtonBaseStyle}" />
                                                    <Button x:Name="SaveJumpHostProfileButton"
                                                            Grid.Column="4"
                                                            VerticalAlignment="Center"
                                                            Click="SaveJumpHostProfileButton_OnClick"
                                                            Content="Save profile"
                                                            Style="{StaticResource PrimaryButtonStyle}" />
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </ScrollViewer>

                        <Grid Grid.Row="2" Margin="0,20,0,0" VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="SaveSettingsButton"
                                    Margin="0,0,8,0"
                                    Click="SaveSettingsButton_OnClick"
                                    Content="Save settings"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <Button x:Name="ClearSavedTokenButton"
                                    Grid.Column="1"
                                    Click="ClearSavedTokenButton_OnClick"
                                    Content="Clear saved token"
                                    Style="{StaticResource ButtonBaseStyle}" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
    </Grid>
    </Border>
</Window>
